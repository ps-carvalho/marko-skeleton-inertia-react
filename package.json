{
  "name": "marko-skeleton-inertia-react",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ssr": "vite build --ssr app/web/resources/js/ssr.jsx --outDir bootstrap/ssr",
    "dev:all": "npm run build:ssr && concurrently -k \"php -S 0.0.0.0:8000 -t public/\" \"npx vite --host\" \"node bootstrap/ssr/ssr.js\" --names \"PHP,VITE,SSR\" --prefix-colors \"blue,green,yellow\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "quality": "npm run lint && npm run format:check && npm run test:ui"
  },
  "dependencies": {
    "@inertiajs/react": "^3.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.3",
    "vitest": "^4.0.15",
    "vite": "^6.0"
  }
}
